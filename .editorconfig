# EditorConfig for Timinute — consumed by IDEs and `dotnet format`.
root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,razor}]
indent_style = space
indent_size = 4

[*.{json,yml,yaml,csproj,props,targets}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
