# Copy to .env and edit. .env is gitignored.

# Bundled SQL Server SA password. SQL Server requires 8+ chars,
# mix of upper/lower/digit/symbol.
MSSQL_SA_PASSWORD=ChangeMe.Strong-Password-123!

# Public URL Timinute is reachable on. MUST be https in production
# and MUST exactly match the URL your reverse proxy serves (no trailing slash).
IdentityServer__Authority=https://timinute.example.com

# Host port. Container always listens on 8080 internally.
TIMINUTE_PORT=8080

# Image tag: `latest` (release), `develop` (preview), or a pinned version like `2.1.0`.
TIMINUTE_TAG=latest

# --- MCP server (AI assistant access at /mcp) --------------------------------
# All optional; sensible defaults shown. See docs/MCP.md and the "MCP server"
# section of docs/DOCKER.md.

# Master switch for the MCP server. Set to false to remove the /mcp endpoint and
# all MCP services entirely (requests to /mcp then fall through to the SPA).
Mcp__Enabled=true

# How many days of AI-activity audit rows (/settings/ai-activity) to keep before
# the background purge removes them.
Mcp__ActivityRetention__Days=90

# How often the AI-activity purge service runs.
Mcp__ActivityRetention__PurgeIntervalHours=24
