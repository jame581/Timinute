{
  "mcpServers": {
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "mssql": {
      "command": "npx",
      "args": ["-y", "mssql-mcp@latest"],
      "env": {
        "DB_SERVER": "127.0.0.1",
        "DB_PORT": "44555",
        "DB_DATABASE": "Timinute",
        "DB_USER": "sa",
        "DB_PASSWORD": "${MSSQL_SA_PASSWORD:-TiminuteAdmin.}",
        "DB_ENCRYPT": "true",
        "DB_TRUST_SERVER_CERTIFICATE": "true"
      }
    }
  }
}
