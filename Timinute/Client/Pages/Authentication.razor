@page "/authentication/{action}"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject NavigationManager Navigation

@if (!IsRegister)
{
    <RemoteAuthenticatorView Action="@Action" />
}

@code {
    [Parameter] public string? Action { get; set; }

    private bool IsRegister => string.Equals(Action, "register", System.StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        // OIDC's RemoteAuthenticatorView does not handle registration — it shows
        // "Registration is not supported." Redirect to the server-side Identity
        // Razor Page that does. The render is gated above so the OIDC fallback
        // never flashes for the frame before NavigateTo takes effect.
        // `replace: true` keeps the back button sane — navigating Back from
        // /Identity/Account/Register goes to the previous page rather than
        // bouncing back through /authentication/register.
        if (IsRegister)
        {
            Navigation.NavigateTo("Identity/Account/Register", forceLoad: true, replace: true);
        }
    }
}
