                <circle cx="12" cy="13" r="7.5" />
                <path d="M12 9v4l2.5 2" />
            </svg>
        </div>
        <span>© @Year Timinute · Built by <a class="lfooter__author" href="@AuthorUrl" target="_blank" rel="noopener">Jan Mesarč</a></span>
    </div>
    <div class="lfooter__links">
        <a class="lfooter__link" href="@GitHubUrl" target="_blank" rel="noopener">GitHub</a>
        <a class="lfooter__link" href="@CoffeeUrl" target="_blank" rel="noopener">Buy me a coffee</a>
        <a class="lfooter__link" href="@LicenseUrl" target="_blank" rel="noopener">License (MIT)</a>
