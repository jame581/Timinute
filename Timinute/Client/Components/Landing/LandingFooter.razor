@code {
    private const string GitHubUrl = "https://github.com/jame581/Timinute";
    private const string CoffeeUrl = "https://www.buymeacoffee.com/jame581";
    private const string LicenseUrl = "https://github.com/jame581/Timinute/blob/master/LICENSE";
    private const string AuthorUrl = "https://github.com/jame581";
