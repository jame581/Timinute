@code {
    public record MonthlyHours(string Label, double Hours);

    [Parameter] public IList<MonthlyHours> Data { get; set; } = new List<MonthlyHours>();

    private double Max => Data.Count == 0 ? 1 : System.Math.Max(1, Data.Max(d => d.Hours));
    private const int PlotHeight = 200;
    private const int BarMaxWidth = 38;
    private const int Padding = 8;
}

<div class="aurora-bar-chart">
    <div class="aurora-bar-chart__plot" style="height: @(PlotHeight)px;">
        <div class="aurora-bar-chart__gridlines">
            @for (int i = 0; i < 4; i++)
            {
                <div class="aurora-bar-chart__gridline" style="bottom: @((i * 25))%;"></div>
            }
        </div>
        <div class="aurora-bar-chart__bars">
            @for (int i = 0; i < Data.Count; i++)
            {
                var d = Data[i];
                var heightPct = (d.Hours / Max) * 100;
                var isLast = i == Data.Count - 1;
                <div class="aurora-bar-chart__col">
                    @if (isLast)
                    {
                        <div class="aurora-bar-chart__tooltip">@($"{d.Hours:0.#}h")</div>
                    }
                    <div class="aurora-bar-chart__bar @(isLast ? "is-last" : "")"
                         style="height: @(heightPct.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%; max-width: @(BarMaxWidth)px;"></div>
                </div>
            }
        </div>
    </div>
    <div class="aurora-bar-chart__labels">
        @for (int i = 0; i < Data.Count; i++)
        {
            var d = Data[i];
            var isLast = i == Data.Count - 1;
            <div class="aurora-bar-chart__label @(isLast ? "is-last" : "")">@d.Label</div>
        }
    </div>
</div>

<style>
    .aurora-bar-chart {
        width: 100%;
    }

    .aurora-bar-chart__plot {
        position: relative;
        margin-bottom: 8px;
    }

    .aurora-bar-chart__gridlines {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    .aurora-bar-chart__gridline {
        position: absolute;
        left: 0;
        right: 0;
        height: 1px;
        border-top: 1px dashed var(--border);
    }

    .aurora-bar-chart__bars {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: flex-end;
        justify-content: space-around;
        gap: 8px;
    }

    .aurora-bar-chart__col {
        position: relative;
        flex: 1;
        height: 100%;
        display: flex;
        align-items: flex-end;
        justify-content: center;
    }

    .aurora-bar-chart__bar {
        width: 100%;
        background: var(--accent-so);
        border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
        border-radius: 8px 8px 4px 4px;
        transition: height .3s ease;
        min-height: 4px;
    }

    .aurora-bar-chart__bar.is-last {
        background: var(--gradient-bar);
        border-color: transparent;
    }

    .aurora-bar-chart__tooltip {
        position: absolute;
        top: -28px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--text);
        color: var(--surface);
        font: 500 11px var(--font-mono);
        padding: 4px 8px;
        border-radius: 6px;
        white-space: nowrap;
        pointer-events: none;
    }

    .aurora-bar-chart__tooltip::after {
        content: "";
        position: absolute;
        bottom: -4px;
        left: 50%;
        transform: translateX(-50%);
        width: 8px;
        height: 8px;
        background: var(--text);
        clip-path: polygon(50% 100%, 0 0, 100% 0);
    }

    .aurora-bar-chart__labels {
        display: flex;
        justify-content: space-around;
        gap: 8px;
        margin-top: 4px;
    }

    .aurora-bar-chart__label {
        flex: 1;
        text-align: center;
        font: 500 11px var(--font-sans);
        color: var(--text-mu);
    }

    .aurora-bar-chart__label.is-last {
        color: var(--text);
        font-weight: 600;
    }
</style>
