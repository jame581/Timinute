@inherits LayoutComponentBase
@implements IDisposable
@inject Timinute.Client.Services.ViewportService Viewport
@inject Timinute.Client.Services.ThemeService Theme
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthState

<head>
    <RadzenTheme Theme="material" @rendermode="RenderMode.InteractiveAuto" />
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js?v=@(typeof(Radzen.Colors).Assembly.GetName().Version)"></script>
</head>

<CascadingValue Value="Viewport.IsMobile" Name="IsMobile">
    <AuthorizeView>
        <Authorized>
            <div class="aurora-app @(Viewport.IsMobile ? "is-mobile" : "")">
                @if (!Viewport.IsMobile)
                {
                    <NavMenu />
                }
                <main class="aurora-main">
                    <Topbar />
                    <article class="aurora-content">
                        @Body
                    </article>
                    @if (Viewport.IsMobile)
                    {
                        <MobileTabBar />
                        <MobileMoreSheet />
                    }
                </main>
            </div>
        </Authorized>
        <NotAuthorized>
            @Body
        </NotAuthorized>
    </AuthorizeView>
</CascadingValue>

<RadzenDialog />
<RadzenNotification />

@code {
    protected override void OnInitialized()
    {
        Viewport.OnChanged += OnViewportChanged;
    }

    private bool themeSynced;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // No `firstRender` guard: InitializeAsync is internally idempotent on success
        // and resets its `initialized` flag on failure, so calling it on every render
        // gives us a free retry path if the first JS import is racing prerender or
        // hot reload. The dedupe is cheap (a single bool check after the first hit).
        await Viewport.InitializeAsync();

        // One-shot theme sync: pulls the authenticated user's preference from
        // the server and writes it into localStorage so cross-device toggles
        // catch up on the next reload. Guarded with a local flag so it runs
        // exactly once per layout instance.
        if (!themeSynced)
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            if (auth.User.Identity?.IsAuthenticated == true)
            {
                themeSynced = true;
                await Theme.SyncFromServerAsync();
            }
        }
    }

    private void OnViewportChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Viewport.OnChanged -= OnViewportChanged;
    }
}
