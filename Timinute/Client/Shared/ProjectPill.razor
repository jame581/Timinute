@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string Color { get; set; } = "#94A3B8";

    private string PillStyle =>
        $"background: {Color}1A; color: {Color};";

    private string DotStyle =>
        $"background: {Color};";
}

<span class="aurora-pill" style="@PillStyle">
    <span class="aurora-pill__dot" style="@DotStyle"></span>
    <span class="aurora-pill__name">@Name</span>
</span>

<style>
    .aurora-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 3px 10px;
        border-radius: var(--r-pill);
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 12px;
        line-height: 1;
        white-space: nowrap;
    }

    .aurora-pill__dot {
        width: 6px;
        height: 6px;
        border-radius: var(--r-pill);
        flex-shrink: 0;
    }

    .aurora-pill__name {
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>
