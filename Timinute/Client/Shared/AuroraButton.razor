@code {
    [Parameter] public string Variant { get; set; } = "primary"; // primary | ghost | soft | sub
    [Parameter] public string? Type { get; set; } = "button";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string VariantClass => $"aurora-btn aurora-btn--{Variant}";
}

<button type="@Type" class="@VariantClass @Class" disabled="@Disabled" title="@Title" @onclick="OnClick">
    @ChildContent
</button>
